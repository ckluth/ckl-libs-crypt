<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>Library</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<LangVersion>latest</LangVersion>
		<AssemblyName>CKL.Libs.Crypt</AssemblyName>
		<RootNamespace>CKL.Libs.Crypt</RootNamespace>
		<PlatformTarget>AnyCPU</PlatformTarget>
		<Version>2.1.0</Version>
		<Authors>ckluth</Authors>
		<Description>Encryption for strings, byte arrays, files, and folders — currently symmetric (AES), reported via the Result pattern.</Description>
		<PackageId>CKL.Libs.Crypt</PackageId>
		<RepositoryType>git</RepositoryType>
		<PackageProjectUrl>https://github.com/ckluth/ckl-libs-crypt</PackageProjectUrl>
		<RepositoryUrl>https://github.com/ckluth/ckl-libs-crypt</RepositoryUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<Copyright>Copyright © 2026 ckluth</Copyright>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageIcon>icon.png</PackageIcon>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
	</PropertyGroup>
	<ItemGroup>
		<None Include="..\README.md" Pack="true" PackagePath="\"/>
		<None Include="..\icon.png" Pack="true" PackagePath="\"/>
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="CKL.Libs.ResultPattern" Version="1.0.0"/>
	</ItemGroup>
</Project>
